<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Al entrar a una tarea -->
    <record id="msg_enter_understand" model="work.item.message.template">
        <field name="name">Quiero entender la tarea.</field>
        <field name="direction">enter</field>
        <field name="sequence">10</field>
    </record>
    <record id="msg_enter_continue" model="work.item.message.template">
        <field name="name">Continúo con el punto anterior.</field>
        <field name="direction">enter</field>
        <field name="sequence">20</field>
    </record>
    <record id="msg_enter_verify_close" model="work.item.message.template">
        <field name="name">Quiero verificar que la tarea se puede cerrar.</field>
        <field name="direction">enter</field>
        <field name="sequence">30</field>
    </record>
    <record id="msg_enter_resume_blocked" model="work.item.message.template">
        <field name="name">Retomo la tarea tras estar bloqueada.</field>
        <field name="direction">enter</field>
        <field name="sequence">40</field>
    </record>
    <record id="msg_enter_review_feedback" model="work.item.message.template">
        <field name="name">Reviso feedback recibido.</field>
        <field name="direction">enter</field>
        <field name="sequence">50</field>
    </record>

    <!-- Al dejar una tarea -->
    <record id="msg_leave_goals_met" model="work.item.message.template">
        <field name="name">Objetivos del inicio cumplidos.</field>
        <field name="direction">leave</field>
        <field name="sequence">10</field>
    </record>
    <record id="msg_leave_continue_with" model="work.item.message.template">
        <field name="name">Se requiere continuar con:</field>
        <field name="direction">leave</field>
        <field name="requires_detail">True</field>
        <field name="sequence">20</field>
    </record>
    <record id="msg_leave_blocked" model="work.item.message.template">
        <field name="name">Se bloqueó la tarea porque:</field>
        <field name="direction">leave</field>
        <field name="requires_detail">True</field>
        <field name="sets_blocked">True</field>
        <field name="sequence">30</field>
    </record>
    <record id="msg_leave_needs_review" model="work.item.message.template">
        <field name="name">Se necesita revisión de otra persona.</field>
        <field name="direction">leave</field>
        <field name="sequence">40</field>
    </record>
    <record id="msg_leave_done" model="work.item.message.template">
        <field name="name">Se terminó la tarea.</field>
        <field name="direction">leave</field>
        <field name="sequence">50</field>
    </record>
    <record id="msg_leave_short_break" model="work.item.message.template">
        <field name="name">Pausa breve, sigo después.</field>
        <field name="direction">leave</field>
        <field name="sequence">60</field>
    </record>
    <record id="msg_leave_continue_tomorrow" model="work.item.message.template">
        <field name="name">Continuo mañana.</field>
        <field name="direction">leave</field>
        <field name="sequence">70</field>
    </record>

</odoo>
