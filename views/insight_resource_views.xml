<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_insight_resource_list" model="ir.ui.view">
        <field name="name">insight.resource.list</field>
        <field name="model">insight.resource</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="source"/>
                <field name="base_efficiency"/>
                <field name="daily_max_hours"/>
            </list>
        </field>
    </record>

    <record id="view_insight_resource_form" model="ir.ui.view">
        <field name="name">insight.resource.form</field>
        <field name="model">insight.resource</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="project_id"/>
                            <field name="source" readonly="1"/>
                        </group>
                        <group>
                            <field name="base_efficiency"/>
                            <field name="daily_max_hours"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Turnos"
                              invisible="source == 'hr'">
                            <field name="shift_ids">
                                <list editable="bottom">
                                    <field name="day_of_week"/>
                                    <field name="hour_from"/>
                                    <field name="hour_to"/>
                                </list>
                            </field>
                        </page>
                        <page string="Vacaciones / Ausencias"
                              invisible="source == 'hr'">
                            <field name="vacation_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
