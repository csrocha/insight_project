<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_insight" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.insight_project</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.view_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block"
                     data-string="TaskJuggler"
                     string="TaskJuggler"
                     data-key="insight_project">
                    <h2>TaskJuggler</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tj_microservice_url"/>
                                <div class="text-muted">
                                    URL base del microservicio TJ3 (ej: https://tj3.example.com)
                                </div>
                                <field name="tj_microservice_url"
                                       placeholder="https://tj3.example.com"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tj_microservice_timeout"/>
                                <div class="text-muted">
                                    Tiempo máximo de espera para el microservicio (segundos)
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <field name="tj_microservice_timeout"/>
                                    <button name="action_test_tj_connection"
                                            type="object"
                                            string="Probar conexión"
                                            class="btn btn-sm btn-secondary"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
