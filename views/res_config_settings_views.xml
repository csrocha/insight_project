<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_insight" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.insight_project</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="project.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='project']" position="inside">
                <block title="TaskJuggler" id="insight_project_taskjuggler">
                    <setting id="tj_microservice_url_setting" help="URL base del microservicio TJ3 (ej: https://tj3.example.com)">
                        <field name="tj_microservice_url" placeholder="https://tj3.example.com"/>
                    </setting>
                    <setting id="tj_microservice_timeout_setting" help="Tiempo máximo de espera para el microservicio (segundos)">
                        <field name="tj_microservice_timeout"/>
                        <div class="content-group">
                            <div class="mt8">
                                <button name="action_test_tj_connection"
                                        type="object"
                                        string="Probar conexión"
                                        class="btn-link"
                                        icon="oi-arrow-right"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
