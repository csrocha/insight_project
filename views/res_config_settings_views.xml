<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Standalone config form — does NOT inherit base_setup.view_general_configuration -->
    <record id="insight_project_config_form" model="ir.ui.view">
        <field name="name">insight.project.config.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Configuración TaskJuggler">
                <sheet>
                    <group string="Microservicio TJ3">
                        <group>
                            <field name="tj_microservice_url"
                                   placeholder="https://tj3.example.com"/>
                        </group>
                        <group>
                            <field name="tj_microservice_timeout"/>
                        </group>
                    </group>
                    <div>
                        <button name="action_test_tj_connection" type="object"
                                string="Probar conexión"
                                class="btn btn-secondary"
                                title="Guarda primero, luego prueba la conexión"/>
                    </div>
                </sheet>
                <footer>
                    <button string="Guardar" name="execute" type="object"
                            class="btn-primary"/>
                    <button string="Descartar" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_insight_project_config" model="ir.actions.act_window">
        <field name="name">Configuración TaskJuggler</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="insight_project_config_form"/>
        <field name="target">inline</field>
        <field name="context">{'module': 'insight_project'}</field>
    </record>
</odoo>
