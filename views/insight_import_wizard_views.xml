<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="insight_import_wizard_form" model="ir.ui.view">
        <field name="name">insight.import.wizard.form</field>
        <field name="model">insight.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar proyecto TJP">
                <field name="state" invisible="1"/>
                <sheet>
                    <field name="state" widget="statusbar"
                           statusbar_visible="upload,mapping"/>

                    <!-- Step 1: Upload -->
                    <group invisible="state != 'upload'">
                        <group>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="tjp_file" widget="binary"
                                   filename="tjp_filename"
                                   string="Archivo TJP"/>
                            <field name="tjp_filename" invisible="1"/>
                        </group>
                        <div class="alert alert-info" role="alert" style="margin-top:8px">
                            Suba un archivo <b>.tjp</b> existente. El asistente lo enviará al
                            microservicio TJ3, detectará las tareas, escenarios y recursos, y le
                            permitirá mapearlos a empleados de Odoo antes de crear el proyecto.
                        </div>
                    </group>

                    <!-- Step 2: Mapping -->
                    <div invisible="state != 'mapping'">
                        <group>
                            <group>
                                <field name="task_count" readonly="1"/>
                                <field name="scenario_names" readonly="1"/>
                            </group>
                        </group>
                        <separator string="Mapeo de recursos"/>
                        <p class="text-muted o_form_label">
                            Los recursos encontrados en el TJP se listan a continuación.
                            Indique cómo mapear cada uno a un empleado existente, crear un
                            nuevo contacto, o ignorarlo.
                        </p>
                        <field name="resource_map_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="tj_resource_id" readonly="1" optional="show"/>
                                <field name="tj_resource_name" readonly="1"/>
                                <field name="action"/>
                                <field name="employee_id"
                                       invisible="action != 'map'"
                                       required="action == 'map'"
                                       optional="show"/>
                            </list>
                        </field>
                    </div>
                </sheet>
                <footer>
                    <button string="Analizar TJP" name="action_analyze"
                            type="object" class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button string="Importar proyecto" name="action_import"
                            type="object" class="btn-primary"
                            invisible="state != 'mapping'"/>
                    <button string="← Volver" name="action_back"
                            type="object"
                            invisible="state != 'mapping'"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_insight_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar proyecto TJP</field>
        <field name="res_model">insight.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'active_id': active_id}</field>
    </record>
</odoo>
