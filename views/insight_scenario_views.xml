<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_insight_scenario_list" model="ir.ui.view">
        <field name="name">insight.scenario.list</field>
        <field name="model">insight.scenario</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="is_baseline"/>
                <field name="total_cost"/>
                <field name="computed_end_date"/>
                <field name="peak_resources"/>
                <field name="selection_score"/>
            </tree>
        </field>
    </record>

    <record id="view_insight_scenario_form" model="ir.ui.view">
        <field name="name">insight.scenario.form</field>
        <field name="model">insight.scenario</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="is_baseline"/>
                    </group>
                    <group string="Resultado del último schedule">
                        <field name="total_cost" readonly="1"/>
                        <field name="computed_end_date" readonly="1"/>
                        <field name="peak_resources" readonly="1"/>
                        <field name="selection_score" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Eficiencias">
                            <field name="efficiency_ids">
                                <tree editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="efficiency"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
