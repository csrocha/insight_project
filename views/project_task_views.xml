<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_view_form_inherit_insight" model="ir.ui.view">
        <field name="name">project.task.form.inherit.insight_project</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_reschedule_project" type="object"
                        string="Replanificar" icon="fa-refresh"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="tj_dependency_type"/>
                <field name="tj_persistent_allocation"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Schedule" name="schedule">
                    <group>
                        <group string="Fechas planificadas">
                            <field name="start_scheduled" readonly="1"/>
                            <field name="end_scheduled" readonly="1"/>
                            <field name="bsi" readonly="1"/>
                        </group>
                        <group string="Estado">
                            <field name="is_critical_path" readonly="1"/>
                        </group>
                    </group>
                    <group string="Tipo de dependencia por bloqueante (override puntual)">
                        <field name="dependency_type_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="depends_on_id"/>
                                <field name="dependency_type"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_task_kanban_inherit_insight" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.insight_project</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="inside">
                <header>
                    <button name="action_reschedule_project" type="object"
                            string="Replanificar" icon="fa-refresh"
                            display="always"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="project_task_view_tree_inherit_insight" model="ir.ui.view">
        <field name="name">project.task.tree.main.base.inherit.insight_project</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.project_task_view_tree_main_base"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <header>
                    <button name="action_reschedule_project" type="object"
                            string="Replanificar" icon="fa-refresh"
                            display="always"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
