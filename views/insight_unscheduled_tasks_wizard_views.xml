<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="insight_unscheduled_tasks_wizard_form" model="ir.ui.view">
        <field name="name">insight.unscheduled.tasks.wizard.form</field>
        <field name="model">insight.unscheduled.tasks.wizard</field>
        <field name="arch" type="xml">
            <form string="La operación requiere atención">
                <field name="project_id" invisible="1"/>
                <field name="suggested_horizon" invisible="1"/>
                <field name="message" readonly="1" nolabel="1"/>
                <footer>
                    <button string="Extender horizonte de planificación"
                            name="action_extend_horizon" type="object"
                            class="btn-primary" invisible="not suggested_horizon"/>
                    <button string="Modificar proyecto"
                            name="action_modify_project" type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
