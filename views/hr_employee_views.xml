<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_inherit_insight" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.insight_project</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='job_title']" position="after">
                <field name="tj_daily_rate"/>
                <field name="tj_daily_max_hours"/>
                <field name="tj_weekly_max_hours"/>
            </xpath>
        </field>
    </record>
</odoo>
