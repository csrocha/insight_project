<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="insight_session_switch_wizard_form" model="ir.ui.view">
        <field name="name">insight.session.switch.wizard.form</field>
        <field name="model">insight.session.switch.wizard</field>
        <field name="arch" type="xml">
            <form string="Cambiar de tarea">
                <field name="mode" invisible="1"/>
                <sheet>
                    <group invisible="not current_task_id">
                        <group string="Tarea que dejás">
                            <field name="current_task_id" readonly="1"/>
                            <field name="previous_intent_note" readonly="1"
                                   invisible="not previous_intent_note"/>
                            <field name="outcome_template_id"/>
                            <field name="outcome_text" nolabel="1"
                                   placeholder="¿Qué se logró en esta tarea?"/>
                        </group>
                    </group>

                    <group invisible="mode != 'switch'">
                        <group string="Tarea que iniciás">
                            <field name="target_task_id"/>
                            <field name="new_task_name"
                                   invisible="target_task_id"/>
                            <field name="new_task_project_id"
                                   invisible="target_task_id or not new_task_name"/>
                            <field name="intent_template_id"/>
                            <field name="intent_text" nolabel="1"
                                   placeholder="¿Qué se va a hacer en esta tarea?"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Cambiar de tarea" name="action_confirm"
                            type="object" class="btn-primary"
                            invisible="mode != 'switch'"/>
                    <button string="Tomar descanso" name="action_confirm"
                            type="object" class="btn-primary"
                            invisible="mode != 'break'"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_insight_session_switch_wizard" model="ir.actions.act_window">
        <field name="name">Cambiar de tarea</field>
        <field name="res_model">insight.session.switch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
