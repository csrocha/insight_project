<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="work_item_session_switch_wizard_form_task" model="ir.ui.view">
        <field name="name">work.item.session.switch.wizard.form.task</field>
        <field name="model">work.item.session.switch.wizard</field>
        <field name="inherit_id" ref="work_item_systray.work_item_session_switch_wizard_form"/>
        <field name="arch" type="xml">
            <field name="target_ref" position="after">
                <field name="new_task_name" invisible="target_ref"/>
                <field name="new_task_project_id" invisible="target_ref or not new_task_name"/>
            </field>
        </field>
    </record>
</odoo>
