<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions for standalone access (Configuration menu) -->
    <record id="action_insight_scenario" model="ir.actions.act_window">
        <field name="name">Escenarios TJ</field>
        <field name="res_model">insight.scenario</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay escenarios definidos aún.
            </p>
            <p>Los escenarios se crean desde la pestaña TaskJuggler de cada proyecto.</p>
        </field>
    </record>

    <record id="action_insight_resource" model="ir.actions.act_window">
        <field name="name">Recursos TJ</field>
        <field name="res_model">insight.resource</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay recursos definidos aún.
            </p>
            <p>Los recursos se crean desde la pestaña TaskJuggler de cada proyecto.</p>
        </field>
    </record>

    <!-- Menus under Project → Configuration -->
    <menuitem id="menu_insight_scenario"
              name="Escenarios TJ"
              parent="project.menu_project_config"
              action="action_insight_scenario"
              groups="project.group_project_manager"
              sequence="100"/>

    <menuitem id="menu_insight_resource"
              name="Recursos TJ"
              parent="project.menu_project_config"
              action="action_insight_resource"
              groups="project.group_project_manager"
              sequence="101"/>

    <menuitem id="menu_insight_config"
              name="Configuración TaskJuggler"
              parent="project.menu_project_config"
              action="action_insight_project_config"
              groups="base.group_system"
              sequence="110"/>
</odoo>
