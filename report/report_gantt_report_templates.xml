<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_gantt_report_svg" name="Gantt (SVG)">
        <html>
            <head>
                <meta charset="utf-8"/>
                <title>Gantt</title>
                <style>
                    body { font-family: Arial, Helvetica, sans-serif; margin: 0; padding: 16px; background: #fafafa; }
                    .o_gantt_report { margin-bottom: 32px; overflow-x: auto; }
                </style>
            </head>
            <body>
                <t t-foreach="reports" t-as="report">
                    <div class="o_gantt_report" t-raw="report['svg']"/>
                </t>
            </body>
        </html>
    </template>
</odoo>
